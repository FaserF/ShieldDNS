{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":pinAllExceptPeerDependencies",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests"
  ],
  "automerge": true,
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
      "rangeStrategy": "replace",
      "groupName": "Go Modules",
      "minimumReleaseAge": null
    },
    {
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "matchDepTypes": ["golang"],
      "rangeStrategy": "replace"
    }
  ],
  "gomod": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^admin/www/admin/index\\.html$/"],
      "matchStrings": ["https://cdnjs\\.cloudflare\\.com/ajax/libs/font-awesome/(?<currentValue>[^/]+)/"],
      "datasourceTemplate": "cdnjs",
      "depNameTemplate": "font-awesome"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^admin/www/admin/index\\.html$/"],
      "matchStrings": ["https://cdn\\.jsdelivr\\.net/npm/chart\\.js@(?<currentValue>[^/\"']+)"],
      "datasourceTemplate": "npm",
      "depNameTemplate": "chart.js"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^admin/main\\.go$/", "/^admin/www/admin/index\\.html$/", "/^admin/www/admin/sw\\.js$/"],
      "matchStrings": ["const Version\\s+=\\s+\"v(?<currentValue>\\d+\\.\\d+\\.\\d+)\"", "\\?v=(?<currentValue>\\d+\\.\\d+\\.\\d+)", "CACHE_NAME = 'shielddns-admin-v(?<currentValue>\\d+\\.\\d+\\.\\d+)'"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "ShieldDNS",
      "packageNameTemplate": "FaserF/ShieldDNS",
      "versioningTemplate": "semver"
    }
  ]
}
